# ===== keylimePi environment =====
# Copy this file to .env (setup.sh will do this for you automatically if you skip it).
# Leave anything blank and setup.sh will detect or generate a sensible value and
# write it back into .env so it's there for next time.

# Timezone, e.g. Australia/Sydney — auto-detected from the OS if left blank.
TZ=

# Hostname used for the Pi-hole container and advertised on the tailnet.
HOSTNAME=keylime-pi

# Pi-hole admin web UI password — auto-generated (and saved here) if left blank.
PIHOLE_PASSWORD=

# UID/GID Jellyfin runs as. 1000:1000 matches the first regular user on a fresh
# CachyOS install — check with `id` if you're not sure.
PUID=1000
PGID=1000

# Where your media library lives on the host. Point this at an existing drive/folder
# if you have one, e.g. /mnt/media. Defaults to ./media inside this repo.
# Starting with one disk now and adding more later? See
# docs/05-storage-simple-vs-naslike.md — this is the only setting that changes.
MEDIA_PATH=./media

# Your home LAN subnet in CIDR form, e.g. 192.168.1.0/24 — this is what Tailscale
# advertises so devices away from home can reach everything on your LAN, not just
# this box. Auto-detected by setup.sh; only set this manually if detection guesses
# wrong (e.g. multiple network interfaces).
LAN_CIDR=

# Optional: a reusable Tailscale auth key (Tailscale admin console → Settings → Keys).
# Leave blank and setup.sh will print a browser login link the first time it runs —
# perfectly fine for a one-off setup, you just need to click the link once.
TAILSCALE_AUTHKEY=

# Advertise this box as a Tailscale exit node, so you can route ALL of a device's
# internet traffic through your home connection (e.g. a consistent home IP while
# travelling). Set to "true" to enable. You still have to approve it once in the
# admin console (Machines → this device → Edit route settings) and select it on the
# client device. IP forwarding is configured by setup.sh either way.
ADVERTISE_EXIT_NODE=false

# Pre-install Jellyfin's official Bookshelf plugin (books & audiobooks) before
# first start, so it's just there with no manual Catalog click-through needed.
# Set to "false" if you'd rather manage plugins entirely from Jellyfin's own UI.
INSTALL_BOOKSHELF_PLUGIN=true
